generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DefaultPreference {
  notificationType String
  channel          String
  enabled          Boolean
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@id([notificationType, channel])
}

model UserPreference {
  id               String   @id @default(cuid())
  userId           String
  notificationType String
  channel          String
  enabled          Boolean
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, notificationType, channel])
  @@index([userId])
}

model QuietHours {
  userId      String   @id
  enabled     Boolean  @default(true)
  startMinute Int
  endMinute   Int
  timezone    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlobalPolicy {
  id               String   @id @default(cuid())
  notificationType String?
  channel          String?
  region           String?
  enabled          Boolean  @default(true)
  reason           String   @default("blocked_by_global_policy")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([notificationType, channel, region])
}
