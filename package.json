{
  "name": "notification-preferences-service",
  "version": "1.0.0",
  "description": "Notification Preferences Service test assignment",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "keywords": [
    "notifications",
    "preferences",
    "fastify",
    "postgresql"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.3",
    "luxon": "^3.6.1",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.15.24",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
